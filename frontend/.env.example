# ─────────────────────────────────────────────────────────────────────
#  ArtBloom frontend environment variables
#  Copy to `.env.local` for dev overrides; on Cloudflare Pages set
#  these in the project's Settings → Environment Variables (Production).
# ─────────────────────────────────────────────────────────────────────

# Backend API base URL.
#   • Dev:        http://localhost:8001  (unset → falls back to this default)
#   • Production: https://artbloom-api.onrender.com
VITE_API_BASE=http://localhost:8001

# Public host serving the textbook-assets/ directory.
#   • Dev:        leave UNSET — LKP JSONs already point at
#                 http://localhost:8001/textbook-assets/... and the
#                 FastAPI StaticFiles mount serves them.
#   • Production: https://pub-xxxxxxxx.r2.dev   (your Cloudflare R2
#                 public bucket; the index.ts rewriter swaps the
#                 hard-coded localhost prefix at runtime).
# VITE_ASSETS_BASE=https://pub-xxxxxxxx.r2.dev

# Caddy reverse proxy for ArtBloom FastAPI backend.
#
# Caddy auto-fetches and renews Let's Encrypt certs for __DOMAIN__
# provided ports 80 + 443 are reachable from the public internet.
# `__DOMAIN__` is substituted by bootstrap.sh.

__DOMAIN__ {
    encode gzip

    reverse_proxy 127.0.0.1:8001 {
        # Disable response buffering so SSE streams from
        # /api/story/stream and /api/story/continue/stream
        # arrive at the browser in real time.
        flush_interval -1

        # Forward original client info to uvicorn so logs/CORS
        # see the real origin.
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Drop default Caddy logs to journald (already done by systemd
    # under `caddy.service`); explicit format here is JSON for grep'ability.
    log {
        output stdout
        format json
        level INFO
    }
}

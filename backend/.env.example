# Volcengine Ark API key (LLM, multimodal, video)
ARK_API_KEY=your_ark_api_key_here

# Volcengine Speech Synthesis V3 — separate from Ark LLM key
# Step 1: go to https://console.volcengine.com/speech/new
# Step 2: enable 语音合成 service if not already active
# Step 3: go to API Key管理 → create/copy key
VOLCENGINE_SPEECH_API_KEY=your_speech_api_key_here
# Optional: resource ID for preset Doubao voices (default is fine for standard voices)
# VOLCENGINE_TTS_RESOURCE_ID=volcano_tts